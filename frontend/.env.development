# Development environment (default)
VITE_API_BASE_URL=http://localhost:8000
VITE_PREPROCESSOR_URL=http://localhost:8001
VITE_SOLVER_URL=http://localhost:8002
VITE_POSTPROCESSOR_URL=http://localhost:8003

# Application settings
VITE_APP_NAME="Antenna Educator"
VITE_APP_VERSION="0.1.0"

# Feature flags
VITE_ENABLE_AUTH=false  # Set to 'true' to require JWT authentication, 'false' for dev stub tokens
VITE_ENABLE_3D_DEBUG=true
