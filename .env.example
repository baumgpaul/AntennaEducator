# =============================================================================
# Antenna Educator — Environment Variables
# Copy to .env and adjust values for your setup.
# =============================================================================

# --- Authentication Mode ---
# "false" = local JWT (Docker/on-prem); "true" = AWS Cognito (production)
USE_COGNITO=false

# --- Local JWT auth (when USE_COGNITO=false) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=generate-a-secure-random-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Admin user seeding (used by scripts/init_local_db.py) ---
# The init script creates this admin user in DynamoDB on first run.
# Change these before running init for the first time.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# --- AWS Cognito auth (when USE_COGNITO=true) ---
COGNITO_REGION=eu-west-1
COGNITO_USER_POOL_ID=your-user-pool-id
COGNITO_CLIENT_ID=your-client-id

# --- DynamoDB ---
USE_DYNAMODB=true
DYNAMODB_ENDPOINT_URL=http://localhost:8000   # DynamoDB Local; remove for AWS
DYNAMODB_TABLE_NAME=antenna-simulator-local
# Host port for DynamoDB Local (avoids collision with API gateway on 8000)
DYNAMODB_LOCAL_PORT=8888

# --- S3 / MinIO (object storage for simulation results) ---
USE_S3=true
S3_ENDPOINT_URL=http://localhost:9000         # MinIO Local; remove for AWS
RESULTS_BUCKET_NAME=antenna-simulator-results-local

# MinIO credentials (must match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD below)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=eu-west-1

# --- Service ports ---
PREPROCESSOR_PORT=8001
SOLVER_PORT=8002
POSTPROCESSOR_PORT=8003

# --- Solver limits ---
SOLVER_MAX_FREQUENCY_POINTS=1000
SOLVER_MAX_EDGES=10000
SOLVER_TIMEOUT_SECONDS=300

# --- Postprocessor defaults ---
POSTPROCESSOR_DEFAULT_THETA_POINTS=181
POSTPROCESSOR_DEFAULT_PHI_POINTS=360

# --- Monitoring profile (docker compose --profile monitoring) ---
# Grafana admin password for http://localhost:3001
GRAFANA_ADMIN_PASSWORD=admin
