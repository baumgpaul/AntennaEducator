# Application Configuration
APP_NAME="Antenna Simulator"
APP_VERSION="0.1.0"
ENVIRONMENT="development"  # development, staging, production

# Service Ports (for standalone deployment)
PREPROCESSOR_PORT=8001
SOLVER_PORT=8002
POSTPROCESSOR_PORT=8003
API_GATEWAY_PORT=8000

# PostgreSQL Configuration (standalone)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=simulator
POSTGRES_USER=user
POSTGRES_PASSWORD=TESTPWD

# MinIO Configuration (standalone S3-compatible storage)
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=TESTPWD
MINIO_BUCKET_GEOMETRIES=geometries
MINIO_BUCKET_RESULTS=solver-results
MINIO_BUCKET_POSTPROCESSOR=postprocessor-results

# AWS Configuration (cloud deployment)
AWS_REGION=us-east-1
AWS_S3_BUCKET=simulator-results
AWS_DYNAMODB_TABLE=simulator-projects

# API Configuration
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json or text

# Security & Authentication
API_KEY_ENABLED=false
API_KEY=your_api_key_here

# JWT Configuration (Docker/Local Mode)
# Used when USE_COGNITO=false for local authentication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
LOCAL_JWT_SECRET=generate_a_secure_random_key_here_32_chars_minimum
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Authentication Mode (CRITICAL SETTING)
# Controls which authentication system is used:
# - USE_COGNITO=false: Docker/On-Premises mode
#   * Users authenticate with local JWT tokens
#   * Passwords stored with bcrypt in DynamoDB
#   * First user automatically becomes admin
#   * All users unlocked by default (no manual approval)
#   * Frontend calls /api/v1/auth/login and /api/v1/auth/register
#
# - USE_COGNITO=true: AWS Cloud mode
#   * Users authenticate with AWS Cognito
#   * Cognito manages passwords and MFA
#   * Email verification required
#   * All users unlocked by default (no manual approval)
#   * Frontend calls same /api/v1/auth/login and /api/v1/auth/register endpoints
USE_COGNITO=false

# AWS Cognito Configuration (only used when USE_COGNITO=true)
COGNITO_REGION=eu-west-1
COGNITO_USER_POOL_ID=your_user_pool_id_here
COGNITO_CLIENT_ID=your_client_id_here

# User Account Status
# is_locked field: Controls whether user can log in
# - is_locked=false (default): User can log in immediately after registration
# - is_locked=true: User account disabled, login returns 403 Forbidden
# Admins can lock/unlock users via admin endpoints in both modes

# Solver Configuration
SOLVER_DEFAULT_METHOD=direct  # direct or iterative
SOLVER_MAX_SEGMENTS=10000
SOLVER_TIMEOUT_SECONDS=300

# Storage
MAX_UPLOAD_SIZE_MB=100
RESULT_RETENTION_DAYS=30
