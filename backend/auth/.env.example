# Auth Service Environment Variables

# Authentication Mode
USE_COGNITO=false  # Set to 'true' for AWS Cognito, 'false' for local JWT auth

# JWT Configuration (for local auth mode)
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# AWS Cognito Configuration (for Cognito mode)
COGNITO_USER_POOL_ID=your-user-pool-id
COGNITO_CLIENT_ID=your-client-id
COGNITO_REGION=eu-west-1

# DynamoDB Configuration
USE_DYNAMODB=false  # Set to 'true' for DynamoDB, 'false' for local storage
DYNAMODB_TABLE_NAME=antenna-simulator-staging
DYNAMODB_ENDPOINT=http://dynamodb-local:8000  # For local DynamoDB
AWS_REGION=eu-west-1
