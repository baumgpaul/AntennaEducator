# Example environment configuration
# Copy this file to .env and update values

# Database
DATABASE_URL=postgresql://antenna:antenna123@postgres:5432/antenna_db

# MinIO Storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=antenna-data
MINIO_SECURE=false

# JWT Authentication
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32

# Authentication Mode
# Set to "false" for Docker mode (local JWT auth, auto-approval)
# Set to "true" for AWS mode (Cognito auth, admin approval required)
USE_COGNITO=false

# AWS Cognito Configuration (only needed if USE_COGNITO=true)
COGNITO_REGION=eu-west-1
COGNITO_USER_POOL_ID=your_user_pool_id_here
COGNITO_CLIENT_ID=your_client_id_here

# Admin Approval Workflow:
# Docker mode: First registered user becomes admin automatically
#              All users are auto-approved (is_approved=true)
# AWS mode:    Users register → verify email → admin approves via Cognito console
#              Admin sets custom:approved=true in Cognito user attributes

