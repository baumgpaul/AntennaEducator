            "position": [0.15, 0.15, 0.005],
            "fields": ["Ez"]
          }
        ],
        "config": {
          "num_time_steps": 1500,
          "courant_number": 0.99,
          "output_every_n_steps": 10,
          "dft_frequencies": [900000000],
          "auto_shutoff_threshold": 1e-6
        }
      },
      "simulation_config": {
        "method": "fdtd",
        "dimensionality": "2d",
        "mode": "tm",
        "requested_fields": ["Ez", "Hx", "Hy"]
      }
    },
