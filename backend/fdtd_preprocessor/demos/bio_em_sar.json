{
  "name": "Bio EM SAR Simulation",
  "description": "Specific Absorption Rate (SAR) quantifies how much electromagnetic energy from a radio source (e.g., mobile phone antenna) is absorbed by biological tissue. This demo models a simplified layered head phantom (skin, bone, brain) exposed to a 900 MHz sinusoidal source, mimicking a mobile phone held near the head. The simulation computes the E-field distribution inside the tissue layers, from which SAR values are derived.",
  "presets": {
    "small": {
      "design_state": {
        "dimensionality": "2d",
        "domainSize": [0.3, 0.3, 0.01],
        "cellSize": [0.01, 0.01, 0.01],
        "structures": [
          {
            "id": "sar-skin",
            "name": "Skin Layer",
            "type": "box",
            "position": [0.15, 0.15, 0.005],
            "dimensions": {"lx": 0.12, "ly": 0.12, "lz": 0.01},
            "material": "skin"
          },
          {
            "id": "sar-bone",
            "name": "Bone Layer",
            "type": "box",
            "position": [0.15, 0.15, 0.005],
            "dimensions": {"lx": 0.1, "ly": 0.1, "lz": 0.01},
            "material": "bone"
          },
          {
            "id": "sar-brain",
            "name": "Brain Tissue",
            "type": "box",
            "position": [0.15, 0.15, 0.005],
            "dimensions": {"lx": 0.06, "ly": 0.06, "lz": 0.01},
            "material": "brain"
          }
        ],
        "sources": [
          {
            "id": "sar-src",
            "name": "Antenna Source (900 MHz)",
            "type": "sinusoidal",
            "position": [0.04, 0.15, 0.005],
            "parameters": {"frequency": 900000000, "amplitude": 1.0},
            "polarization": "z"
          }
        ],
        "boundaries": {
