            "position": [0.16, 0.12, 0.005],
            "fields": ["Ey", "Hz"]
          },
          {
            "id": "emc-probe-nf",
            "name": "Near-field Above Bend",
            "type": "point",
            "position": [0.16, 0.1, 0.005],
            "fields": ["Ez", "Ey"]
          }
        ],
        "config": {
          "num_time_steps": 1000,
