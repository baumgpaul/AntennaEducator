{
  "name": "EMC/EMI PCB Trace Analysis",
  "description": "Electromagnetic Compatibility (EMC) analysis of a PCB microstrip trace with a 90-degree bend on an FR-4 substrate. A Gaussian pulse excites one end of the trace and propagates along it. The bend creates impedance discontinuities that cause reflections and radiation. Probes at both ends of the trace measure incident and transmitted signals for S-parameter extraction (return loss S11, insertion loss S21), while a near-field probe above the trace monitors radiated emissions.",
  "presets": {
    "small": {
      "design_state": {
        "dimensionality": "2d",
        "domainSize": [0.3, 0.15, 0.01],
        "cellSize": [0.005, 0.005, 0.01],
