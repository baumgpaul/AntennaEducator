            "type": "gaussian_pulse",
            "position": [0.25, 0.4, 0.005],
            "parameters": {"frequency": 1000000000, "bandwidth": 500000000},
            "polarization": "z"
          }
        ],
        "boundaries": {
          "x_min": {"type": "mur_abc"},
          "x_max": {"type": "mur_abc"},
          "y_min": {"type": "mur_abc"},
