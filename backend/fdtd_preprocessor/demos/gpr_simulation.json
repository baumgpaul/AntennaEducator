{
  "name": "Ground Penetrating Radar (GPR)",
  "description": "Ground Penetrating Radar sends a short electromagnetic pulse into the ground and detects reflections from subsurface layers and buried objects. This 2D demo models a layered soil profile (dry soil on top, wet soil beneath) with a buried metallic target. A Gaussian pulse source at the surface generates a broadband signal that propagates downward, reflects off material interfaces and the target, and returns to surface probes for B-scan analysis.",
  "presets": {
    "small": {
      "design_state": {
        "dimensionality": "2d",
        "domainSize": [0.5, 0.5, 0.01],
        "cellSize": [0.005, 0.005, 0.01],
        "structures": [
          {
            "id": "gpr-air",
            "name": "Air Layer",
            "type": "box",
            "position": [0.25, 0.425, 0.005],
            "dimensions": {"lx": 0.5, "ly": 0.15, "lz": 0.01},
            "material": "air"
          },
          {
            "id": "gpr-dry-soil",
            "name": "Dry Soil Layer",
            "type": "box",
            "position": [0.25, 0.25, 0.005],
            "dimensions": {"lx": 0.5, "ly": 0.2, "lz": 0.01},
            "material": "dry_soil"
          },
          {
            "id": "gpr-wet-soil",
            "name": "Wet Soil Layer",
            "type": "box",
            "position": [0.25, 0.075, 0.005],
            "dimensions": {"lx": 0.5, "ly": 0.15, "lz": 0.01},
            "material": "wet_soil"
          },
          {
            "id": "gpr-target",
            "name": "Buried Metal Target",
            "type": "box",
            "position": [0.25, 0.2, 0.005],
            "dimensions": {"lx": 0.04, "ly": 0.04, "lz": 0.01},
            "material": "pec"
          }
        ],
        "sources": [
