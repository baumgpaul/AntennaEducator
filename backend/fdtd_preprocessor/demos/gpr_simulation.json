          {
            "id": "gpr-probe-sub",
            "name": "Subsurface Probe",
            "type": "point",
            "position": [0.25, 0.25, 0.005],
            "fields": ["Ez"]
          }
        ],
        "config": {
          "num_time_steps": 1500,
          "courant_number": 0.99,
          "output_every_n_steps": 10,
          "dft_frequencies": [500000000, 750000000, 1000000000, 1250000000, 1500000000],
          "auto_shutoff_threshold": 1e-6
        }
      },
      "simulation_config": {
        "method": "fdtd",
        "dimensionality": "2d",
