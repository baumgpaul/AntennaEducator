frontend/node_modules
frontend/dist
frontend/.vite

# Version control
.git
.github

# Test outputs and artifacts
test_outputs
tests/test_outputs
build_log.txt
coverage/

# Editor and IDE files
.vscode
.idea
*.pyc
__pycache__

# Terraform state (large, not needed for app)
terraform/.terraform

# Environment files (use env_file in compose)
.env
.env.*
